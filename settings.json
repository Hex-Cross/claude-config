{
  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Edit",
      "MultiEdit",
      "Glob",
      "Grep",
      "Agent",
      "Skill",
      "WebSearch",
      "WebFetch",
      "TaskCreate",
      "TaskGet",
      "TaskList",
      "TaskUpdate",
      "mcp__ide__getDiagnostics",
      "mcp__ide__executeCode",
      "mcp__playwright__*",
      "mcp__claude_ai_Atlassian__*",
      "mcp__claude_ai_Gmail__*",
      "Bash(*)",
      "NotebookEdit",
      "ToolSearch",
      "TaskOutput",
      "TaskStop",
      "CronCreate",
      "CronDelete",
      "CronList",
      "RemoteTrigger",
      "mcp__exa__*",
      "mcp__firecrawl__*",
      "mcp__context7__*",
      "mcp__sequential-thinking__*"
    ],
    "deny": [
      "Bash(git commit*)",
      "Bash(git push*)"
    ],
    "defaultMode": "auto"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"/home/frok/.claude/hooks/gsd-check-update.js\""
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"/home/frok/.claude/hooks/bootstrap-detect.mjs\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|Edit|Write|MultiEdit|Agent|Task",
        "hooks": [
          {
            "type": "command",
            "command": "node \"/home/frok/.claude/hooks/gsd-context-monitor.js\"",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node \"/home/frok/.claude/hooks/auto-format.js\"",
            "timeout": 15
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node \"/home/frok/.claude/hooks/config-sync-monitor.mjs\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node \"/home/frok/.claude/hooks/plugin-context-trigger.mjs\"",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"/home/frok/.claude/hooks/skill-auto-trigger.mjs\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"/home/frok/.claude/hooks/gsd-prompt-guard.js\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"/home/frok/.claude/hooks/gsd-workflow-guard.js\"",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "node /home/frok/.claude/hooks/gsd-statusline.js"
  },
  "extraKnownMarketplaces": {
    "vercel-vercel-plugin": {
      "source": {
        "source": "directory",
        "path": "/home/frok/.cache/plugins/github.com-vercel-vercel-plugin"
      }
    }
  },
  "voiceEnabled": true,
  "skipDangerousModePermissionPrompt": true,
  "skipAutoPermissionPrompt": true,
  "enabledPlugins": {
    "vercel-plugin@vercel-vercel-plugin": true
  }
}
